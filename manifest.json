{
  "manifest_version": 3,
  "name": "ShieldBlock — Ad Blocker",
  "version": "1.0.0",
  "description": "A powerful, privacy-first ad blocker that eliminates ads, trackers, and annoyances without affecting website content.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "css": ["content/cosmetic-filters.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ads_rules",
        "enabled": true,
        "path": "rules/ads-rules.json"
      },
      {
        "id": "tracker_rules",
        "enabled": true,
        "path": "rules/tracker-rules.json"
      },
      {
        "id": "annoyance_rules",
        "enabled": true,
        "path": "rules/annoyance-rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["content/cosmetic-filters.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
